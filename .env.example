# ============================================================
# 莱钢 AI 问数 — 环境变量模板
# 使用方法：cp .env.example .env && 填写真实值
# 注意：.env 文件禁止提交 Git！
# ============================================================

# ===== 应用 =====
APP_ENV=development              # development | production
APP_SECRET_KEY=REPLACE_WITH_RANDOM_32CHARS_STRING_FOR_JWT
APP_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
PROJECT_NAME=lgsteel

# ===== Docker 宿主机端口（与 docker-compose.yml 严格对应）=====
HOST_PORT_NGINX_HTTP=8100
HOST_PORT_NGINX_HTTPS=8143
HOST_PORT_BACKEND=8101
HOST_PORT_META_DB=5441
HOST_PORT_BIZ_DB=5442
HOST_PORT_REDIS=6391
HOST_PORT_CHROMA=8191

# ===== 元数据库 =====
META_DB_HOST=meta_db             # 容器内服务名；宿主机 IDE 调试改为 127.0.0.1
META_DB_PORT=5432
META_DB_NAME=lgsteel_meta
META_DB_USER=lgsteel_meta_user
META_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ===== 业务数据库 =====
BIZ_DB_HOST=biz_db
BIZ_DB_PORT=5432
BIZ_DB_NAME=lgsteel_biz
BIZ_DB_USER=lgsteel_biz_user
BIZ_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
REDIS_DB=0

# ===== ChromaDB =====
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ===== LLM — 通义千问 =====
QIANWEN_API_KEY=
QIANWEN_MODEL=qwen-max

# ===== LLM — 文心一言 =====
WENXIN_API_KEY=
WENXIN_SECRET_KEY=
WENXIN_MODEL=ernie-4.0-8k

# ===== LLM 通用 =====
LLM_TIMEOUT_SECONDS=15
LLM_MAX_TOKENS_PER_REQUEST=2000
LLM_DAILY_TOKEN_BUDGET=5000000
LLM_DAILY_TOKEN_BUDGET_PER_USER=100000

# ===== 安全 =====
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
ALLOW_ORIGINS=http://internal.lgsteel.com   # 禁止配置为 *

# ===== 查询限制 =====
QUERY_MAX_ROWS=10000
QUERY_TIMEOUT_SECONDS=30
MAX_SQL_RETRY=3

# ===== Excel =====
EXCEL_MAX_SIZE_MB=50
EXCEL_UPLOAD_DIR=/app/files/excel
EXCEL_MAX_BATCH_FILES=10
FIELD_MAPPING_CONFIRM_THRESHOLD=0.70

# ===== 对话管理 =====
MAX_CONVERSATION_TURNS=10
CONVERSATION_TTL_SECONDS=7200

# ===== 数据时效预警 =====
DATASOURCE_STALE_DAYS=7
